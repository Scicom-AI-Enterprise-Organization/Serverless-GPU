# Copy to .env and edit. Never commit .env.
# .env is read by docker-compose automatically.

# Phase 0 (local docker-compose, no real GPU): the fake worker uses this
# app_id so it BRPOPs the right queue. After you `serverlessgpu deploy`
# an endpoint with name=qwen, this will line up.
PHASE0_APP_ID=qwen
PHASE0_MODEL=Qwen/Qwen2.5-7B-Instruct

# Prime Intellect API key. Required when AUTOSCALER=1 PROVIDER=primeintellect.
# Get a fresh one from the PI dashboard — never paste keys into shells, chat,
# or commits.
PI_API_KEY=replace-me

# PI custom template — id of a template you've baked containing our worker-agent
# (+ vllm). The PI API has no `userData` / cloud-init field, so the only way
# to ship our worker code is via a pre-baked template.
PI_CUSTOM_TEMPLATE_ID=replace-me

# Public URL of the gateway, reachable from PI's network. Workers dial this
# from their PI pods to register and heartbeat.
GATEWAY_PUBLIC_URL=https://your.gateway.example.com

# Optional PI tuning (sane defaults applied if unset)
# PI_API_BASE=https://api.primeintellect.ai
# PI_PROVIDER_TYPE=runpod
# PI_CLOUD_ID=
# PI_GPU_SOCKET=PCIe
# PI_DATA_CENTER_ID=
# PI_MAX_PRICE_HR=2.50

# Toggle the autoscaler. Off in Phase 0 (compose runs one fake worker manually),
# on in Phase 1+ for dynamic provisioning.
AUTOSCALER=0
PROVIDER=fake

# Gateway listen address — leave default for local dev.
GATEWAY_BIND=0.0.0.0:8080

# Where the Python CLI looks for the gateway.
SERVERLESSGPU_GATEWAY=http://localhost:8080

# API-key auth on the gateway. Comma-separated list of accepted bearer tokens.
# Empty = auth disabled (dev mode). MUST be set before exposing the gateway
# publicly. Generate keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
GATEWAY_API_KEYS=

# CLI side: which key to send. Pick one from GATEWAY_API_KEYS.
SERVERLESSGPU_API_KEY=
