# sgpu inference agent — wraps the upstream vLLM image and adds:
#   - ready-checkin to the gateway when /health goes 200
#   - graceful shutdown handling
#   - (future) GPU metrics push, log forwarding
#
# Built and pushed by CI to ECR Public so PI hosts can pull without AWS auth.
# Pulled and `docker run`-ed by the bash bootstrap that ssh-bootstraps each
# PI bare-metal pod.
FROM vllm/vllm-openai:latest

# curl is needed by the entrypoint health watcher
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY worker-agent/entrypoint-inference.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# vLLM defaults to 8000; we keep that as the contract.
EXPOSE 8000

# IMPORTANT: override vllm/vllm-openai's default entrypoint so we can
# orchestrate health-watching alongside vllm serve.
ENTRYPOINT ["/entrypoint.sh"]
